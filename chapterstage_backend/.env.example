APP_ENV=development
API_BASE_URL=http://localhost:8000
PUBLIC_SITE_BASE_URL=http://localhost:8000/public/experiences
DATABASE_URL=sqlite+aiosqlite:///./chapterstage.db
GENERATED_SITE_ROOT=./static/generated
MAX_UPLOAD_MB=20
MAX_CHAPTER_CHARS=80000
MIN_CHAPTER_CHARS=500
LOG_LEVEL=INFO

# Selectable Band transport. Keep `test` for local dev/tests.
BAND_TRANSPORT_MODE=test
BAND_API_KEY=
BAND_API_URL=https://app.band.ai
BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
BAND_AGENT_UUID_COORDINATOR=
BAND_AGENT_UUID_STRUCTURE=
BAND_AGENT_UUID_PEDAGOGY=
BAND_AGENT_UUID_BRAINSTORM=
BAND_AGENT_UUID_VISUAL_BUILDER=
BAND_AGENT_UUID_VERIFIER=

# Planned provider layer defaults.
LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=
